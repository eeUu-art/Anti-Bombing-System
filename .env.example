# 应用密钥（必须修改为随机字符串）
SECRET_KEY=your-random-secret-key-here

# 加密密钥（必须修改为随机字符串）
ENCRYPTION_KEY=your-encryption-key-here

# 调试模式（true/false）
DEBUG=false

# 数据库连接（MySQL 或 SQLite）
# MySQL: mysql://user:password@host:port/dbname
# SQLite: sqlite:///anti_bomb.db
DB_CONNECTION_STRING=mysql://root:root123@127.0.0.1:3306/anti_bomb_db

# Redis 连接
REDIS_URL=redis://localhost:6379/0
